{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mario/projects/wheelwright/framework/WAI-Spoke/_hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mario/projects/wheelwright/framework/.claude/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mario/projects/wheelwright/framework/.claude/hooks/pre-tool-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mario/projects/wheelwright/framework/.claude/hooks/stop-test-runner.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/mario/projects/wheelwright/framework/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/mario/.claude/statusline.sh",
    "padding": 2,
    "refreshInterval": 30
  }
}
